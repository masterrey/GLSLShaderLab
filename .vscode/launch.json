    "version": "0.2.0",
    "configurations": [
        {
            "name": "Studio (WPF) — novo",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-studio",
            "program": "${workspaceFolder}/src/GLSLShaderLab.App.Wpf/bin/Debug/net9.0-windows/GLSLShaderLab.App.Wpf.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Legacy (console) — antigo",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-legacy",
            "program": "${workspaceFolder}/bin/Debug/net9.0/GLSLShaderLab.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}